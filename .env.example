# Local Clip Studio — Environment Configuration
# Copy this file to .env and adjust values as needed.

# --- Application ---
LOCALCLIP_STORAGE_PATH=${HOME:-~}/.localclip
LOCALCLIP_LOG_LEVEL=INFO
LOCALCLIP_LOG_FORMAT=json
LOCALCLIP_MAX_IMPORT_SIZE_GB=50
LOCALCLIP_MAX_CONCURRENT_JOBS=2

# --- GPU (auto-detect by default) ---
# Options: auto, cuda, mps, rocm, cpu
LOCALCLIP_GPU_BACKEND=auto
LOCALCLIP_GPU_MEMORY_LIMIT_PERCENT=80

# --- FFmpeg ---
# Leave empty to use system PATH
LOCALCLIP_FFMPEG_PATH=
LOCALCLIP_FFPROBE_PATH=

# --- API ---
LOCALCLIP_API_HOST=0.0.0.0
LOCALCLIP_API_PORT=8765
LOCALCLIP_CORS_ORIGINS=http://localhost:5173,http://localhost:4173

# --- Celery (Background Jobs) ---
# Use filesystem:// for local-only, redis://localhost:6379 for Redis
LOCALCLIP_CELERY_BROKER_URL=filesystem://
LOCALCLIP_CELERY_RESULT_BACKEND=db+sqlite:///${LOCALCLIP_STORAGE_PATH}/celery_results.db

# --- AI Providers (Optional — set API keys in app UI) ---
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=
# GEMINI_API_KEY=
# OPENROUTER_API_KEY=
# GROQ_API_KEY=
# TOGETHER_API_KEY=
# FIREWORKS_API_KEY=
# DEEPINFRA_API_KEY=
# MISTRAL_API_KEY=
# NVIDIA_API_KEY=
