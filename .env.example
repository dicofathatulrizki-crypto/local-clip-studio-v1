# Local Clip Studio — Environment Configuration

# Application
LOCALCLIP_ENVIRONMENT=development
LOCALCLIP_API__HOST=127.0.0.1
LOCALCLIP_API__PORT=8765
LOCALCLIP_API__DEBUG=true

# Database
# Default: ~/.localclip/projects/localclip.db (auto-created)
# LOCALCLIP_DATABASE__URL=sqlite+aiosqlite:////home/user/.localclip/projects/localclip.db

# Storage
# Default: ~/.localclip (auto-created)
# LOCALCLIP_STORAGE__BASE_PATH=/home/user/.localclip

# Logging
LOCALCLIP_LOGGING__LEVEL=INFO
LOCALCLIP_LOGGING__FORMAT=json

# GPU (auto-detect by default)
LOCALCLIP_GPU__BACKEND=auto
# LOCALCLIP_GPU__MEMORY_LIMIT_MB=4096

# Queue
# LOCALCLIP_QUEUE__BROKER_URL=redis://localhost:6379/0
# LOCALCLIP_QUEUE__RESULT_BACKEND=redis://localhost:6379/0
